# ── Service Account Credentials ───────────────────────────────────────────────
# Path to the service account JSON file (must have bigquery.jobs.create permission)
# Can be absolute or relative to the eval/ folder
CREDENTIALS_PATH=sa.json

# Also read by some Google client libraries automatically:
GOOGLE_APPLICATION_CREDENTIALS=sa.json

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_PROJECT_ID=cognito-prod-394707
BQ_DATASET_ID=cognito_prod_datamart
BQ_LOE_TABLE_NAME=Master_LOE
BQ_LOCATION=asia-south1

# ── Gemini (used by ipd3bq__6_.py — Gemini pipeline) ─────────────────────────
GEMINI_API_KEY=<YOUR_GEMINI_API_KEY>

# ── Claude / Vertex AI (used by ipd3bq_claude.py — Claude pipeline) ──────────
# Claude Sonnet 4.6 via Anthropic Vertex AI
CLAUDE_MODEL=claude-sonnet-4-6
GCP_REGION=us-east5

# ── Optional ──────────────────────────────────────────────────────────────────
# Override the local JSON output directory (default: ./ipd3_output/)
# IPD3_OUTPUT_DIR=./ipd3_output
